{
    "name": "daun/statamic-cache-directives",
    "description": "Parse conditional comments for dynamic fragments in cached Statamic pages",
    "license": "MIT",
    "keywords": [
        "statamic",
        "cache",
        "directives",
        "static-caching"
    ],
    "authors": [
        {
            "name": "Philipp Daun",
            "email": "post@philippdaun.net",
            "homepage": "https://philippdaun.net"
        }
    ],
    "homepage": "https://github.com/daun/statamic-cache-directives",
    "require": {
        "php": "^8.4",
        "statamic/cms": "^5.0 || ^6.0",
        "symfony/expression-language": "^7.4 || ^8.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9 || ^3.0",
        "laravel/pint": "^1.14",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Daun\\StatamicCacheDirectives\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "pixelfear/composer-dist-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "analyse": "./vendor/bin/phpstan analyse --memory-limit=2G",
        "format": "./vendor/bin/pint",
        "lint": "./vendor/bin/pint --test",
        "test": "./vendor/bin/pest",
        "test:ci": "./vendor/bin/pest --coverage-clover coverage.xml",
        "test:coverage": "./vendor/bin/pest --coverage"
    }
}
